generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  // url is configured in prisma.config.ts (Prisma 7 — no url field in schema)
}

// ============================================================
// AUTH
// ============================================================

enum Role {
  ADMIN
  VENDEDOR
  ASISTENTE
}

model User {
  id            Int                @id @default(autoincrement())
  name          String
  email         String             @unique
  password      String
  role          Role               @default(ASISTENTE)
  active        Boolean            @default(true)
  emailVerified DateTime?
  image         String?
  deletedAt     DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  accounts      Account[]
  sessions      Session[]
  activities    ContactActivity[]
  forms         CrmForm[]
  campaigns     CrmCampaign[]
  sales         CrmSale[]
  templates     CampaignTemplate[]
  segments      Segment[]
  landings      Landing[]
  flows         Flow[]
  auditLogs     AuditLog[]

  @@index([deletedAt])
}

model Account {
  id                Int     @id @default(autoincrement())
  userId            Int
  type              String  @db.VarChar(64)
  provider          String  @db.VarChar(64)
  providerAccountId String  @db.VarChar(191)
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String? @db.VarChar(64)
  scope             String? @db.VarChar(191)
  id_token          String? @db.Text
  session_state     String? @db.VarChar(191)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           Int      @id @default(autoincrement())
  sessionToken String   @unique @db.VarChar(191)
  userId       Int
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String   @db.VarChar(191)
  token      String   @unique @db.VarChar(191)
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// CONTACTOS
// ============================================================

enum ContactSource {
  WEBINAR
  FORM
  MANUAL
  IMPORT
}

enum ContactStatus {
  NEW
  QUALIFIED
  CLIENT
}

enum ActivityType {
  NOTE
  EMAIL_SENT
  WEBINAR_REGISTERED
  WEBINAR_ATTENDED
  COURSE_PURCHASED
  FORM_SUBMITTED
  CAMPAIGN_SENT
  SALE_CREATED
}

model Contact {
  id                 Int                    @id @default(autoincrement())
  name               String
  email              String                 @unique
  phone              String?
  source             ContactSource          @default(MANUAL)
  status             ContactStatus          @default(NEW)
  deletedAt          DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  tags               ContactTag[]
  activities         ContactActivity[]
  deals              Deal[]
  sales              CrmSale[]
  registrations      WebinarRegistration[]
  formSubmissions    CrmFormSubmission[]
  campaignRecipients CrmCampaignRecipient[]
  flowRuns           FlowRun[]

  @@index([status, source, createdAt])
  @@index([source, createdAt])
  @@index([deletedAt])
}

model Tag {
  id        Int          @id @default(autoincrement())
  name      String       @unique
  color     String       @default("#6366f1")
  deletedAt DateTime?
  contacts  ContactTag[]

  @@index([deletedAt])
}

model ContactTag {
  contactId Int
  tagId     Int
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
}

model ContactActivity {
  id          Int          @id @default(autoincrement())
  contactId   Int
  type        ActivityType @default(NOTE)
  body        String?      @db.Text
  createdAt   DateTime     @default(now())
  createdById Int?
  contact     Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdBy   User?        @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([contactId, createdAt])
}

// ============================================================
// PIPELINE & VENTAS
// ============================================================

enum DealStage {
  LEAD
  DEMO
  NEGOTIATION
  ENROLLED
}

enum CrmSaleStatus {
  PENDING
  PAID
  REFUNDED
  CANCELED
}

enum CrmPaymentMethod {
  CASH
  TRANSFER
  CARD
  STRIPE
  PAYPAL
  OTHER
}

model Deal {
  id         Int       @id @default(autoincrement())
  contact    Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId  Int
  courseName String?
  stage      DealStage @default(LEAD)
  notes      String?   @db.Text
  sales      CrmSale[]
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([contactId, stage])
  @@index([stage, updatedAt])
  @@index([courseName])
  @@index([deletedAt])
}

model CrmSale {
  id                    Int              @id @default(autoincrement())
  contactId             Int
  contact               Contact          @relation(fields: [contactId], references: [id], onDelete: Cascade)
  dealId                Int?
  deal                  Deal?            @relation(fields: [dealId], references: [id], onDelete: SetNull)
  productName           String
  amountCents           Int
  currency              String           @default("MXN") @db.VarChar(3)
  status                CrmSaleStatus    @default(PAID)
  paymentMethod         CrmPaymentMethod @default(OTHER)
  soldAt                DateTime         @default(now())
  notes                 String?          @db.Text
  createdById           Int?
  createdBy             User?            @relation(fields: [createdById], references: [id], onDelete: SetNull)
  stripeSessionId       String?          @unique @db.VarChar(191)
  stripePaymentIntentId String?          @unique @db.VarChar(191)
  stripeCustomerId      String?          @db.VarChar(191)
  deletedAt             DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([status, soldAt])
  @@index([contactId, soldAt])
  @@index([dealId])
  @@index([createdById, soldAt])
  @@index([productName])
  @@index([deletedAt])
}

model StripeEvent {
  id          Int       @id @default(autoincrement())
  eventId     String    @unique @db.VarChar(191)
  type        String    @db.VarChar(64)
  payload     Json
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([type, createdAt])
}

// ============================================================
// WEBINARS
// ============================================================

enum RegistrationStatus {
  REGISTERED
  ATTENDED
  PURCHASED
}

model Webinar {
  id            Int                   @id @default(autoincrement())
  title         String
  date          DateTime
  platform      String?
  link          String?
  description   String?               @db.Text
  viewerCount   Int?
  deletedAt     DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  registrations WebinarRegistration[]
  integration   WebinarIntegration?

  @@index([deletedAt])
  @@index([date])
}

model WebinarRegistration {
  id        Int                @id @default(autoincrement())
  webinar   Webinar            @relation(fields: [webinarId], references: [id], onDelete: Cascade)
  webinarId Int
  contact   Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId Int
  status    RegistrationStatus @default(REGISTERED)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@unique([webinarId, contactId])
  @@index([contactId, status])
  @@index([webinarId, status])
}

model WebinarIntegration {
  id            Int         @id @default(autoincrement())
  webinarId     Int         @unique
  webinar       Webinar     @relation(fields: [webinarId], references: [id], onDelete: Cascade)
  integrationId Int
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  externalId    String?     @db.VarChar(191)
  config        Json?
  lastSyncAt    DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([integrationId])
  @@index([externalId])
}

// ============================================================
// FORMULARIOS
// ============================================================

enum CrmFormStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CrmFormFieldType {
  SHORT_TEXT
  FULL_NAME
  PHONE
  PHONE_WITH_COUNTRY
  EMAIL
  CUSTOM_DATE
  CUSTOM_TIME
  CUSTOM_DATETIME
}

enum CrmFormContactTarget {
  NONE
  NAME
  EMAIL
  PHONE
}

model CrmForm {
  id             Int                 @id @default(autoincrement())
  name           String
  slug           String              @unique @db.VarChar(191)
  status         CrmFormStatus       @default(DRAFT)
  description    String?             @db.Text
  submitLabel    String              @default("Enviar")
  successMessage String              @default("Gracias, recibimos tus datos.")
  createdById    Int?
  createdBy      User?               @relation(fields: [createdById], references: [id], onDelete: SetNull)
  fields         CrmFormField[]
  submissions    CrmFormSubmission[]
  landings       Landing[]
  deletedAt      DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([createdById])
  @@index([status, updatedAt])
  @@index([deletedAt])
}

model CrmFormField {
  id            Int                      @id @default(autoincrement())
  formId        Int
  form          CrmForm                  @relation(fields: [formId], references: [id], onDelete: Cascade)
  type          CrmFormFieldType
  contactTarget CrmFormContactTarget     @default(NONE)
  label         String
  fieldKey      String                   @db.VarChar(191)
  placeholder   String?
  helpText      String?                  @db.Text
  isRequired    Boolean                  @default(false)
  position      Int                      @default(0)
  config        Json?
  values        CrmFormSubmissionValue[]
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  @@unique([formId, fieldKey])
  @@index([formId, position])
}

model CrmFormSubmission {
  id          Int                      @id @default(autoincrement())
  formId      Int
  form        CrmForm                  @relation(fields: [formId], references: [id], onDelete: Cascade)
  contactId   Int?
  contact     Contact?                 @relation(fields: [contactId], references: [id], onDelete: SetNull)
  submittedAt DateTime                 @default(now())
  ipHash      String?
  userAgent   String?                  @db.Text
  values      CrmFormSubmissionValue[]

  @@index([formId, submittedAt])
  @@index([formId, contactId])
  @@index([contactId])
}

model CrmFormSubmissionValue {
  id              Int               @id @default(autoincrement())
  submissionId    Int
  submission      CrmFormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  fieldId         Int
  field           CrmFormField      @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  rawValue        String?           @db.Text
  normalizedValue String?           @db.VarChar(191)

  @@unique([submissionId, fieldId])
  @@index([fieldId, normalizedValue])
}

// ============================================================
// CAMPAÑAS
// ============================================================

enum CrmCampaignChannel {
  EMAIL
  WHATSAPP
}

enum CrmCampaignStatus {
  DRAFT
  SENDING
  SENT
  PARTIAL
  FAILED
  ARCHIVED
}

enum CrmCampaignRecipientStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

model CrmCampaign {
  id              Int                    @id @default(autoincrement())
  name            String
  subject         String
  previewText     String?
  fromName        String?
  fromEmail       String?
  bodyHtml        String?                @db.Text
  bodyText        String?                @db.Text
  channel         CrmCampaignChannel     @default(EMAIL)
  status          CrmCampaignStatus      @default(DRAFT)
  filters         Json?
  audienceLabel   String                 @default("Todos los contactos")
  projectName     String?
  recipientCount  Int                    @default(0)
  sentCount       Int                    @default(0)
  failedCount     Int                    @default(0)
  sentAt          DateTime?
  createdById     Int?
  createdBy       User?                  @relation(fields: [createdById], references: [id], onDelete: SetNull)
  templateId      Int?
  template        CampaignTemplate?      @relation(fields: [templateId], references: [id], onDelete: SetNull)
  segmentId       Int?
  segment         Segment?               @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  waTemplateName  String?                @db.VarChar(191)
  waLanguage      String?                @db.VarChar(16)
  waVariables     Json?
  recipients      CrmCampaignRecipient[]
  deletedAt       DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([createdById, status, updatedAt])
  @@index([status, sentAt])
  @@index([projectName])
  @@index([channel, status])
  @@index([templateId])
  @@index([segmentId])
  @@index([deletedAt])
}

model CrmCampaignRecipient {
  id           Int                        @id @default(autoincrement())
  campaignId   Int
  campaign     CrmCampaign                @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId    Int?
  contact      Contact?                   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  email        String
  name         String?
  status       CrmCampaignRecipientStatus @default(PENDING)
  errorMessage String?                    @db.Text
  sentAt       DateTime?
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt

  @@unique([campaignId, contactId])
  @@index([campaignId, status])
  @@index([contactId, status])
  @@index([email])
}

model CampaignTemplate {
  id          Int                @id @default(autoincrement())
  name        String
  channel     CrmCampaignChannel
  subject     String?
  previewText String?
  bodyHtml    String?            @db.Text
  bodyText    String?            @db.Text
  waTemplate  String?            @db.VarChar(191)
  variables   Json?
  createdById Int?
  createdBy   User?              @relation(fields: [createdById], references: [id], onDelete: SetNull)
  campaigns   CrmCampaign[]
  deletedAt   DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([channel])
  @@index([createdById])
  @@index([deletedAt])
}

model Segment {
  id          Int           @id @default(autoincrement())
  name        String        @unique
  description String?       @db.Text
  filters     Json
  isDynamic   Boolean       @default(true)
  createdById Int?
  createdBy   User?         @relation(fields: [createdById], references: [id], onDelete: SetNull)
  campaigns   CrmCampaign[]
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([createdById])
  @@index([deletedAt])
}

// ============================================================
// INTEGRACIONES
// ============================================================

enum IntegrationProvider {
  ZOOM
  STREAMYARD
  STRIPE
  WHATSAPP_CLOUD
  SMTP
}

enum IntegrationStatus {
  ACTIVE
  DISABLED
  ERROR
}

model Integration {
  id                  Int                  @id @default(autoincrement())
  provider            IntegrationProvider  @unique
  status              IntegrationStatus    @default(ACTIVE)
  config              Json
  lastSyncAt          DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  webinarIntegrations WebinarIntegration[]

  @@index([status])
}

// ============================================================
// AUDITORÍA
// ============================================================

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  STAGE_CHANGE
  LOGIN
}

model AuditLog {
  id         Int         @id @default(autoincrement())
  actorId    Int?
  actor      User?       @relation(fields: [actorId], references: [id], onDelete: SetNull)
  entityType String      @db.VarChar(64)
  entityId   Int
  action     AuditAction
  changes    Json?
  metadata   Json?
  createdAt  DateTime    @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
}

// ============================================================
// LANDINGS
// ============================================================

enum LandingStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LandingBlockType {
  HERO
  VIDEO
  CTA
  FORM_EMBED
  TESTIMONIALS
  FAQ
  FOOTER
  CUSTOM_HTML
}

model Landing {
  id            Int            @id @default(autoincrement())
  name          String
  slug          String         @unique @db.VarChar(191)
  status        LandingStatus  @default(DRAFT)
  title         String?
  description   String?        @db.Text
  ogImageUrl    String?
  faviconUrl    String?
  customHead    String?        @db.Text
  customCss     String?        @db.Text
  formId        Int?
  form          CrmForm?       @relation(fields: [formId], references: [id], onDelete: SetNull)
  ownFormConfig Json?
  flowId        Int?
  flow          Flow?          @relation("LandingFlow", fields: [flowId], references: [id], onDelete: SetNull)
  blocks        LandingBlock[]
  views         LandingView[]
  createdById   Int?
  createdBy     User?          @relation(fields: [createdById], references: [id], onDelete: SetNull)
  deletedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([status, updatedAt])
  @@index([deletedAt])
  @@index([createdById])
  @@index([formId])
  @@index([flowId])
}

model LandingBlock {
  id         Int              @id @default(autoincrement())
  landingId  Int
  landing    Landing          @relation(fields: [landingId], references: [id], onDelete: Cascade)
  type       LandingBlockType
  position   Int              @default(0)
  config     Json
  customHtml String?          @db.Text
  customCss  String?          @db.Text
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([landingId, position])
}

model LandingView {
  id        Int      @id @default(autoincrement())
  landingId Int
  landing   Landing  @relation(fields: [landingId], references: [id], onDelete: Cascade)
  ipHash    String   @db.VarChar(64)
  uaHash    String   @db.VarChar(64)
  referer   String?  @db.Text
  utm       Json?
  viewedAt  DateTime @default(now())

  @@index([landingId, viewedAt])
  @@index([ipHash, landingId])
}

// ============================================================
// FLOWS
// ============================================================

enum FlowTrigger {
  FORM_SUBMITTED
  LANDING_VIEWED
  LANDING_SUBMITTED
  WEBINAR_REGISTERED
  WEBINAR_ATTENDED
  SALE_PAID
}

enum FlowStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum FlowStepAction {
  REDIRECT
  ASSIGN_TAG
  MOVE_DEAL
  CREATE_DEAL
  SEND_EMAIL
  SEND_WHATSAPP
  UPDATE_CONTACT_STATUS
  WAIT
}

enum FlowRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELED
}

model Flow {
  id            Int         @id @default(autoincrement())
  name          String
  description   String?     @db.Text
  trigger       FlowTrigger
  triggerConfig Json?
  status        FlowStatus  @default(DRAFT)
  steps         FlowStep[]
  runs          FlowRun[]
  landings      Landing[]   @relation("LandingFlow")
  createdById   Int?
  createdBy     User?       @relation(fields: [createdById], references: [id], onDelete: SetNull)
  deletedAt     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([trigger, status])
  @@index([deletedAt])
  @@index([createdById])
}

model FlowStep {
  id        Int            @id @default(autoincrement())
  flowId    Int
  flow      Flow           @relation(fields: [flowId], references: [id], onDelete: Cascade)
  position  Int            @default(0)
  action    FlowStepAction
  config    Json
  delayMins Int            @default(0)
  runs      FlowRunStep[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([flowId, position])
}

model FlowRun {
  id             Int           @id @default(autoincrement())
  flowId         Int
  flow           Flow          @relation(fields: [flowId], references: [id], onDelete: Cascade)
  contactId      Int?
  contact        Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  triggerPayload Json?
  status         FlowRunStatus @default(PENDING)
  startedAt      DateTime      @default(now())
  finishedAt     DateTime?
  steps          FlowRunStep[]
  errorMessage   String?       @db.Text
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([flowId, status, startedAt])
  @@index([contactId, startedAt])
}

model FlowRunStep {
  id           Int           @id @default(autoincrement())
  runId        Int
  run          FlowRun       @relation(fields: [runId], references: [id], onDelete: Cascade)
  stepId       Int
  step         FlowStep      @relation(fields: [stepId], references: [id], onDelete: Cascade)
  position     Int
  status       FlowRunStatus @default(PENDING)
  runAt        DateTime
  executedAt   DateTime?
  result       Json?
  errorMessage String?       @db.Text
  attempts     Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status, runAt])
  @@index([runId, position])
}
